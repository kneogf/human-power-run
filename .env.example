# =============================================================
# HUMAN POWER RUN — 環境変数テンプレート
# .env.local にコピーして使う（.env.local はリポジトリにコミットしない）
# =============================================================

# -------------------------------------------------------------
# Vercel KV / Upstash Redis
#   - Vercel Marketplace で KV を追加すると KV_REST_API_* が自動設定される
#   - 単体 Upstash を使う場合は UPSTASH_REDIS_REST_* を使う
#   - /api/scores 用（GET=リーダーボード, POST=スコア送信）
#   - /api/scores POST のレート制限にも同じ Redis を再利用する
# -------------------------------------------------------------
KV_REST_API_URL=
KV_REST_API_TOKEN=
# もしくは ↓ どちらか一方でよい
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
